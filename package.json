{
  "name": "literacy-site-theme",
  "version": "1.0.0",
  "description": "Reusable Docusaurus v3 theme package for Literacy for Kids curriculum sites",
  "main": "./src/index.js",
  "type": "commonjs",
  "exports": {
    ".": "./src/index.js",
    "./package.json": "./package.json",
    "./navbarItems": "./src/data/navbarItems.js",
    "./footerConfig": "./src/data/footerConfig.js",
    "./ecosystemLinks": "./src/data/ecosystemLinks.js",
    "./EcosystemLinks": "./src/theme/EcosystemLinks/index.js",
    "./LiteracyNavbar": "./src/theme/LiteracyNavbar/index.js",
    "./LiteracyFooter": "./src/theme/LiteracyFooter/index.js"
  },
  "files": [
    "src"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "keywords": [
    "docusaurus",
    "docusaurus-theme",
    "literacy",
    "curriculum",
    "education"
  ],
  "engines": {
    "node": ">=18.0"
  },
  "peerDependencies": {
    "@docusaurus/core": "^3.0.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/literacy-for-kids/literacy_site_template.git"
  },
  "homepage": "https://github.com/literacy-for-kids/literacy_site_template",
  "bugs": {
    "url": "https://github.com/literacy-for-kids/literacy_site_template/issues"
  }
}